{
  "schema": "elastos.capsule/v1",
  "name": "webrtc-signal-provider",
  "version": "0.0.1",
  "description": "WebRTC SDP/ICE signaling over Carrier gossip (media stays browser-to-browser)",
  "author": "HeyElastos",
  "role": "provider",
  "type": "microvm",
  "entrypoint": "rootfs.ext4",
  "provides": "elastos://webrtc-signal/*",
  "capabilities": ["localhost://ElastOS/SystemServices/WebRTCSignal/*"],
  "resources": {
    "memory_mb": 64,
    "gpu": false
  }
}
